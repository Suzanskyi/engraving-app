# Database Configuration
# PostgreSQL connection settings for Docker container

# Database host (localhost when using Docker)
DB_HOST=localhost

# Database port (mapped from Docker container)
DB_PORT=5432

# Database name for development
DB_NAME=suzengrave

# Database name for testing
DB_TEST_NAME=suzengrave_test

# Database user (Docker container default)
DB_USER=postgres

# Database password (Docker container password)
DB_PASSWORD=suzengrave123

# Connection pool settings
# Maximum number of connections in pool (default: 20 for dev, 50 for prod)
DB_POOL_SIZE=20

# Idle timeout in milliseconds (default: 30000)
DB_IDLE_TIMEOUT=30000

# Connection timeout in milliseconds (default: 2000)
DB_CONNECTION_TIMEOUT=2000

# SSL configuration (disabled for Docker development)
DB_SSL=false

# Application environment
NODE_ENV=development